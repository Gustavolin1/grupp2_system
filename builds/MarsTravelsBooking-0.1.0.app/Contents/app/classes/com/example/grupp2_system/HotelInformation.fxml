<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #cdeaf8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.grupp2_system.HotelInformationController">
   <children>
      <Button fx:id="btnBack" layoutX="641.0" layoutY="500.0" mnemonicParsing="false" onAction="#back" prefHeight="52.0" prefWidth="100.0" style="-fx-background-radius: 100; -fx-background-color: #5c96c6;" text="Tillbaka" textFill="WHITE">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
      <Label fx:id="titleHotel" layoutX="249.0" layoutY="31.0" text="Hotellinformation" textFill="#5c96c6">
