<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.grupp2_system.loadcashcardcontroller">
   <children>
      <Label layoutX="57.0" layoutY="39.0" text="Välj summa som du vill ladda ditt betalkort med:">
         <font>
            <Font size="22.0" />
         </font>
      </Label>
      <TextField fx:id="txtfieldsum" layoutX="217.0" layoutY="118.0" />
      <Text layoutX="57.0" layoutY="84.0" strokeType="OUTSIDE" strokeWidth="0.0" text="(Minsta tillåtna summa: 20 000 kr)" />
      <Button fx:id="btnback" layoutX="57.0" layoutY="314.0" mnemonicParsing="false" onAction="#btnback" text="Tillbaka" />
      <Button fx:id="btnnext" layoutX="502.0" layoutY="314.0" mnemonicParsing="false" onAction="#btnnext" text="Nästa" />
   </children>
</AnchorPane>
