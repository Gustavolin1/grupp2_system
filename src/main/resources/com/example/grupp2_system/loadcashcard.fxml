<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #cdeaf8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.grupp2_system.loadcashcardcontroller">

    <children>

        <!-- Title -->
        <Label layoutX="213.0" layoutY="35.0" prefHeight="79.0" prefWidth="373.0" text="Ladda ditt betalkort inför resan" textFill="#2685b9">
            <font>
                <Font name="Hannotate SC Bold" size="27.0" />
            </font>
        </Label>

        <!-- Instruction -->
        <Label layoutX="220.0" layoutY="147.0" text="Välj summa som du vill ladda kortet med:" textFill="#2685b9">
            <font>
                <Font name="Hannotate SC Bold" size="20.0" />
            </font>
        </Label>

        <!-- Minimum info -->
        <Text fill="#2685b9" layoutX="310.0" layoutY="279.0" strokeType="OUTSIDE" strokeWidth="0.0" text="(Minsta tillåtna summa: 20 000 kr)" />

        <!-- Input -->
        <TextField fx:id="txtfieldsum" layoutX="285.0" layoutY="230.0" prefHeight="36.0" prefWidth="230.0" style="-fx-background-color: #2685b9; -fx-text-fill: white;" />

        <!-- Back button -->
        <Button fx:id="btnback" layoutX="70.0" layoutY="480.0" mnemonicParsing="false" onAction="#btnback" prefHeight="38.0" prefWidth="104.0" style="-fx-background-color: #2685b9;" text="Tillbaka" textFill="WHITE" AnchorPane.bottomAnchor="42.6" AnchorPane.leftAnchor="70.0">
            <font>
                <Font size="17.0" />
            </font>
        </Button>

        <!-- Next button -->
        <Button fx:id="btnnext" layoutX="600.0" layoutY="480.0" mnemonicParsing="false" onAction="#btnnext" prefHeight="38.0" prefWidth="104.0" style="-fx-background-color: #2685b9;" text="Nästa" textFill="WHITE" AnchorPane.bottomAnchor="42.6" AnchorPane.rightAnchor="70.0">
            <font>
                <Font size="17.0" />
            </font>
        </Button>

    </children>
</AnchorPane>
