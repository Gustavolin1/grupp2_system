<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #cdeaf8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.grupp2_system.TravelDateController">
   <children>
      <Label alignment="CENTER" layoutX="137.0" layoutY="256.0" prefHeight="43.0" prefWidth="132.0" text="År" textFill="#2685b9" AnchorPane.leftAnchor="137.0">
         <font>
            <Font size="25.0" />
         </font></Label>
      <Label layoutX="232.0" layoutY="18.0" prefHeight="79.0" prefWidth="362.0" text="Välj datum för resa till Mars" textFill="#2685b9" textOverrun="CLIP">
         <font>
            <Font name="Hannotate SC Bold" size="27.0" />
         </font>
      </Label>
      <Button fx:id="btnBack" layoutX="69.0" layoutY="479.0" mnemonicParsing="false" onAction="#cancelBooking" prefHeight="40.0" prefWidth="132.0" style="-fx-background-color: #2685b9;" text="Avbryt bokning " textFill="WHITE">
         <font>
            <Font size="16.0" />
