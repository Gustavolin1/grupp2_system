      <Button fx:id="btnForward" layoutX="619.0" layoutY="480.0" mnemonicParsing="false" onAction="#next" prefHeight="40.0" prefWidth="132.0" style="-fx-background-color: #2685b9;" text="Gå vidare" textFill="WHITE">
